---
import { getCollection } from 'astro:content'
import type { GetStaticPaths } from 'astro'

// Rein für den Build-Prozess: rendert pro Artikel/Projekt mit Cover-Bild eine
// statische Seite, die per Playwright zu einem OG-Bild (1200×630) geschossen
// wird. Kein Teil der öffentlichen Navigation — noindex.
//
// Bewusst KEIN WebGL/Canvas-Shader hier (anders als das Halbton-Bild auf der
// echten Seite): Chromium stürzt im Vercel-Build-Sandbox beim WebGL2-Kontext
// zuverlässig ab (auch mit SwiftShader-Software-Rendering-Flags), was den
// gesamten Screenshot-Lauf für alle Bilder mitreißt. Graustufen-Filter +
// SVG-feTurbulence-Grain (dieselbe Technik wie GrainOverlay.astro) liefern
// eine optisch sehr ähnliche, aber reine CSS/SVG-Annäherung ohne GPU-Prozess.
export const getStaticPaths: GetStaticPaths = async () => {
  const posts = await getCollection('blog', ({ data }) => !data.draft && data.coverImage)
  const projects = await getCollection('projects', ({ data }) => data.coverImage)

  const blogPaths = posts.map((post) => ({
    params: { kind: 'blog', slug: post.id.replace(/\.md$/, '') },
    props: { coverImage: post.data.coverImage as string },
  }))

  const projectPaths = projects.map((project) => ({
    params: { kind: 'projects', slug: project.id.replace(/\.md$/, '') },
    props: { coverImage: project.data.coverImage as string },
  }))

  return [...blogPaths, ...projectPaths]
}

const { coverImage } = Astro.props
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="robots" content="noindex, nofollow" />
    <title>og-render</title>
    <style>
      html, body { margin: 0; padding: 0; background: #fff; }
      #frame { position: relative; width: 1200px; height: 630px; overflow: hidden; }
      .frame-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        filter: grayscale(1) contrast(1.15);
      }
      .frame-grain {
        position: absolute;
        inset: 0;
        filter: url(#og-grain);
        opacity: 0.1;
        mix-blend-mode: overlay;
        pointer-events: none;
      }
    </style>
  </head>
  <body>
    <svg style="display:none" aria-hidden="true">
      <defs>
        <filter id="og-grain" x="0%" y="0%" width="100%" height="100%" color-interpolation-filters="sRGB">
          <feTurbulence type="fractalNoise" baseFrequency="0.65" numOctaves="3" stitchTiles="stitch" result="noiseOut" />
          <feColorMatrix type="saturate" values="0" in="noiseOut" result="greyNoise" />
          <feBlend in="SourceGraphic" in2="greyNoise" mode="overlay" result="blended" />
          <feComposite in="blended" in2="SourceGraphic" operator="in" />
        </filter>
      </defs>
    </svg>
    <div id="frame">
      <img class="frame-img" src={coverImage} alt="" />
      <div class="frame-grain"></div>
    </div>
  </body>
</html>
