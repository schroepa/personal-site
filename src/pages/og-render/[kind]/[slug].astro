---
import HalftoneImage, { DEFAULT_HALFTONE_PARAMS } from '@/components/HalftoneImage'
import { getCollection } from 'astro:content'
import '@/styles/global.css'
import type { GetStaticPaths } from 'astro'

// Rein für den Build-Prozess: rendert pro Artikel/Projekt mit Cover-Bild eine
// statische Seite, die per Playwright zu einem Halbton-OG-Bild (1200×630)
// geschossen wird. Kein Teil der öffentlichen Navigation — noindex.
export const getStaticPaths: GetStaticPaths = async () => {
  const posts = await getCollection('blog', ({ data }) => !data.draft && data.coverImage)
  const projects = await getCollection('projects', ({ data }) => data.coverImage)

  const blogPaths = posts.map((post) => ({
    params: { kind: 'blog', slug: post.id.replace(/\.md$/, '') },
    props: { coverImage: post.data.coverImage as string },
  }))

  const projectPaths = projects.map((project) => ({
    params: { kind: 'projects', slug: project.id.replace(/\.md$/, '') },
    props: { coverImage: project.data.coverImage as string },
  }))

  return [...blogPaths, ...projectPaths]
}

const { coverImage } = Astro.props
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="robots" content="noindex, nofollow" />
    <title>og-render</title>
    <style>
      html, body { margin: 0; padding: 0; background: #fff; }
      #frame { width: 1200px; height: 630px; overflow: hidden; }
      .frame-img { width: 100%; height: 100%; }
    </style>
  </head>
  <body>
    <div id="frame">
      <HalftoneImage
        client:only="react"
        src={coverImage}
        alt=""
        className="frame-img"
        config={DEFAULT_HALFTONE_PARAMS}
      />
    </div>
  </body>
</html>
