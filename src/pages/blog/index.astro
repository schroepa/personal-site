---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { Badge } from '@/components/ui/badge';
import { getCollection } from 'astro:content';
import { readingTime } from '@/lib/reading-time';

const posts = await getCollection('blog', ({ data }) => !data.draft);
const sorted = posts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const formatDate = (date: Date) =>
  new Intl.DateTimeFormat('de-DE', { year: 'numeric', month: 'long', day: 'numeric' }).format(date);
---

<BaseLayout title="Blog — Patrick Schröder" description="Gedanken zu Design, Frontend und Tooling.">
  <div class="px-6 pt-32 pb-24">
    <div class="max-w-2xl mx-auto">

      <header class="mb-16">
        <h1 class="t-h1 mb-4" data-reveal="lines">Blog</h1>
        <p class="t-lead text-muted-foreground">
          Gedanken zu Design, Frontend-Entwicklung und den Tools dazwischen.
        </p>
      </header>

      <div class="post-list">
        {sorted.map((post) => (
          <article class="post-entry" data-scroll="fade-up">
            <a href={`/blog/${post.id.replace(/\.md$/, '')}`} class="post-link" data-cursor="link">

              <!-- Bild als Anker — volle Breite, vor dem Text -->
              <div class="post-image">
                {post.data.coverImage ? (
                  <img
                    src={post.data.coverImage}
                    alt=""
                    loading="lazy"
                    decoding="async"
                    class="post-img"
                  />
                ) : (
                  <div class="post-img-fallback" aria-hidden="true"></div>
                )}
              </div>

              <!-- Typografischer Block -->
              <div class="post-body">
                <div class="post-meta">
                  <time datetime={post.data.date.toISOString()}>
                    {formatDate(post.data.date)}
                  </time>
                  <span>·</span>
                  <span>{readingTime(post.body ?? '')} min</span>
                </div>

                <h2 class="post-title">{post.data.title}</h2>
                <p class="post-desc">{post.data.description}</p>

                {post.data.tags && post.data.tags.length > 0 && (
                  <div class="post-tags">
                    {post.data.tags.map((tag) => (
                      <Badge variant="secondary" client:visible>{tag}</Badge>
                    ))}
                  </div>
                )}
              </div>

            </a>
          </article>
        ))}
      </div>

    </div>
  </div>
</BaseLayout>

<style>
  /* ── Listengitter ────────────────────────────────────────────────────────── */
  .post-list {
    display: flex;
    flex-direction: column;
  }

  .post-entry {
    padding-bottom: 3.5rem;
    margin-bottom: 3.5rem;
    border-bottom: 1px solid color-mix(in oklch, var(--foreground) 8%, transparent);
  }

  .post-entry:last-child {
    border-bottom: none;
    margin-bottom: 0;
  }

  .post-link {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  /* ── Bild als Anker ─────────────────────────────────────────────────────── */
  .post-image {
    width: 100%;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    margin-bottom: 1.5rem;
  }

  .post-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 600ms cubic-bezier(0.25, 1, 0.5, 1);
  }

  .post-link:hover .post-img {
    transform: scale(1.03);
  }

  .post-img-fallback {
    width: 100%;
    height: 100%;
    background:
      radial-gradient(ellipse 80% 80% at 20% 30%,
        color-mix(in oklch, var(--mesh-warm) 55%, transparent) 0%, transparent 70%),
      radial-gradient(ellipse 60% 60% at 80% 70%,
        color-mix(in oklch, var(--mesh-cool) 45%, transparent) 0%, transparent 65%),
      var(--muted);
  }

  /* ── Typografischer Block ───────────────────────────────────────────────── */
  .post-body {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    font-weight: 500;
    color: var(--muted-foreground);
  }

  .post-title {
    font-size: var(--text-xl);
    font-weight: 500;
    line-height: var(--leading-snug);
    letter-spacing: var(--tracking-snug);
    color: var(--foreground);
    margin: 0.25rem 0 0;
    transition: opacity 200ms ease;
  }

  .post-link:hover .post-title {
    opacity: 0.6;
  }

  .post-desc {
    font-size: var(--text-base);
    line-height: var(--leading-normal);
    color: var(--muted-foreground);
    margin: 0;
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 0.5rem;
  }

  @media (prefers-reduced-motion: reduce) {
    .post-img { transition: none; }
  }
</style>
