---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { readingTime } from '@/lib/reading-time';
import HalftoneImage, { DEFAULT_HALFTONE_PARAMS } from '@/components/HalftoneImage';

const posts = await getCollection('blog', ({ data }) => !data.draft);
const sorted = posts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const formatDate = (date: Date) =>
  new Intl.DateTimeFormat('de-DE', { year: 'numeric', month: 'short' }).format(date);
---

<BaseLayout title="Blog — Patrick Schröder" description="Gedanken zu Design, Frontend und Tooling.">
  <!-- Hero: Header linksbündig am unteren Viewport-Rand -->
  <div class="page-grid page-hero">
    <header class="blog-header">
      <h1 class="t-h1 mb-4" data-reveal="lines">Blog</h1>
      <p class="t-lead text-muted-foreground prose-col">
        Gedanken zu Design, Frontend-Entwicklung und den Tools dazwischen.
      </p>
    </header>
  </div>

  <!-- Liste scrollt darunter weiter -->
  <div class="page-grid pb-24">
    <ol class="post-list" aria-label="Alle Artikel">
      {sorted.map((post) => {
        const slug = post.id.replace(/\.md$/, '')
        const mins = readingTime(post.body ?? '')

        return (
          <li class="post-item">
            <a
              href={`/blog/${slug}`}
              class="post-link"
              data-cursor="link"
            >
              <!-- Thumbnail: immer sichtbar, kompakt -->
              <div class="post-thumb" aria-hidden="true">
                {post.data.coverImage ? (
                  <HalftoneImage
                    client:only="react"
                    src={post.data.coverImage.startsWith('/images/blog/')
                      ? post.data.coverImage.replace(/\.webp$/, '-480.webp')
                      : post.data.coverImage}
                    alt=""
                    className="post-thumb-img"
                    config={DEFAULT_HALFTONE_PARAMS}
                  />
                ) : (
                  <div class="post-thumb-fallback"></div>
                )}
              </div>

              <!-- Textblock: Meta, Titel, Beschreibung, Tags -->
              <div class="post-body">
                <div class="post-meta">
                  <time datetime={post.data.date.toISOString()}>
                    {formatDate(post.data.date)}
                  </time>
                  <span aria-hidden="true">·</span>
                  <span>{mins} min</span>
                </div>

                <h2 class="post-title">{post.data.title}</h2>
                <p class="post-desc">{post.data.description}</p>

                {post.data.tags && post.data.tags.length > 0 && (
                  <div class="post-tags">
                    {post.data.tags.map((tag) => (
                      <span class="post-tag">{tag}</span>
                    ))}
                  </div>
                )}
              </div>
            </a>
          </li>
        )
      })}
    </ol>

  </div>
</BaseLayout>

<style>
  /* ── Hero: volle Viewporthöhe, Header unten links ───────────────────── */
  .page-hero {
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding-bottom: 5rem;
  }

  /* ── Header ──────────────────────────────────────────────────────────── */
  .blog-header {
    margin-bottom: 0;
  }

  /* ── Liste ───────────────────────────────────────────────────────────── */
  .post-list {
    list-style: none;
    padding: 0;
    margin: 0;
    border-top: 1px solid color-mix(in oklch, var(--foreground) 12%, transparent);
  }

  .post-item {
    /* Link übernimmt die gesamte Fläche */
  }

  /* ── Zeile: Thumbnail | Text ─────────────────────────────────────────── */
  .post-link {
    display: grid;
    grid-template-columns: clamp(80px, 12vw, 160px) 1fr;
    gap: 1.5rem;
    align-items: start;
    padding: 1.25rem 0;
    border-bottom: 1px solid color-mix(in oklch, var(--foreground) 12%, transparent);
    text-decoration: none;
    color: var(--foreground);
    transition: opacity 250ms ease;
  }

  .post-link:focus-visible {
    outline: 2px solid var(--foreground);
    outline-offset: 4px;
  }

  /* Kontext-Dimming: nicht-gehoverte Einträge zurücktreten */
  .post-list:has(.post-link:hover) .post-link:not(:hover) {
    opacity: 0.25;
  }

  /* ── Thumbnail ───────────────────────────────────────────────────────── */
  .post-thumb {
    width: 100%;
    aspect-ratio: 3 / 2;
    overflow: hidden;
    background: var(--muted);
    flex-shrink: 0;
  }

  .post-thumb-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 500ms cubic-bezier(0.25, 1, 0.5, 1);
  }

  .post-link:hover .post-thumb-img {
    transform: scale(1.04);
  }

  .post-thumb-fallback {
    width: 100%;
    height: 100%;
    background:
      radial-gradient(ellipse 80% 80% at 20% 30%,
        color-mix(in oklch, var(--mesh-warm) 50%, transparent) 0%, transparent 70%),
      radial-gradient(ellipse 60% 60% at 80% 70%,
        color-mix(in oklch, var(--mesh-cool) 40%, transparent) 0%, transparent 65%),
      var(--muted);
  }

  /* ── Textblock ───────────────────────────────────────────────────────── */
  .post-body {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    padding-top: 0.125rem; /* optische Ausrichtung mit Thumbnail-Oberkante */
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--muted-foreground);
    margin-bottom: 0.25rem;
  }

  .post-title {
    font-size: var(--text-base);
    font-weight: 500;
    line-height: var(--leading-snug);
    letter-spacing: var(--tracking-snug);
    margin: 0;
  }

  .post-desc {
    font-size: var(--text-sm);
    line-height: var(--leading-normal);
    color: var(--muted-foreground);
    margin: 0.125rem 0 0;
    /* Maximal 2 Zeilen anzeigen */
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* ── Tags: plain text, kein Pill ────────────────────────────────────── */
  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.625rem;
    margin-top: 0.375rem;
  }

  .post-tag {
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--muted-foreground);
  }

  /* ── Mobile ──────────────────────────────────────────────────────────── */
  @media (max-width: 480px) {
    .post-link {
      grid-template-columns: 80px 1fr;
      gap: 1rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .post-link,
    .post-thumb-img { transition: none; }
    .post-link:hover .post-thumb-img { transform: none; }
  }
</style>
