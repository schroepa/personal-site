---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { Card, CardHeader, CardTitle, CardDescription } from '@/components/ui/card';
import { Badge } from '@/components/ui/badge';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog', ({ data }) => !data.draft);
const sorted = posts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const formatDate = (date: Date) =>
  new Intl.DateTimeFormat('de-DE', { year: 'numeric', month: 'long', day: 'numeric' }).format(date);
---

<BaseLayout title="Blog — Patrick Schröder" description="Gedanken zu Design, Frontend und Tooling.">
  <div class="px-6 pt-32 pb-24">
    <div class="max-w-5xl mx-auto">
      <header class="mb-16">
        <h1 class="t-h1 mb-4" data-reveal="lines">Blog</h1>
        <p class="t-lead text-muted-foreground">
          Gedanken zu Design, Frontend-Entwicklung und den Tools dazwischen.
        </p>
      </header>

      <div class="grid gap-4">
        {sorted.map((post) => (
          <a href={`/blog/${post.id.replace(/\.md$/, '')}`} class="group block no-underline" data-cursor="link">
            <Card
              data-scroll="fade-up"
              client:visible
              className="!p-0 overflow-hidden transition-all duration-300 group-hover:border-foreground/20 group-hover:bg-muted/50"
            >
              <div class="card-inner">
                <!-- Thumbnail: flush mit Card-Kante, kein äußeres Padding -->
                <div class="thumbnail-wrap">
                  {post.data.coverImage ? (
                    <img
                      src={post.data.coverImage}
                      alt=""
                      class="thumbnail-img"
                      loading="lazy"
                      decoding="async"
                    />
                  ) : (
                    <div class="thumbnail-placeholder" aria-hidden="true"></div>
                  )}
                </div>

                <!-- Text: eigenes Padding, unabhängig vom Thumbnail -->
                <div class="card-text">
                  <time
                    class="t-label text-muted-foreground"
                    datetime={post.data.date.toISOString()}
                  >
                    {formatDate(post.data.date)}
                  </time>
                  <div class="flex flex-col gap-2 mt-2">
                    <CardTitle className="t-h3">
                      {post.data.title}
                    </CardTitle>
                    <CardDescription className="t-body text-muted-foreground">
                      {post.data.description}
                    </CardDescription>
                  </div>
                  {post.data.tags && post.data.tags.length > 0 && (
                    <div class="flex flex-wrap gap-2 mt-4">
                      {post.data.tags.map((tag) => (
                        <Badge variant="secondary" client:visible>{tag}</Badge>
                      ))}
                    </div>
                  )}
                </div>
              </div>
            </Card>
          </a>
        ))}
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  /* Card-Layout: Thumbnail flush links, Text mit Padding rechts */
  .card-inner {
    display: flex;
    flex-direction: column;
    min-height: 140px;
  }

  @media (min-width: 640px) {
    .card-inner {
      flex-direction: row;
      align-items: stretch;
    }
  }

  /* Thumbnail: stretch über volle Höhe der Card, kein Padding */
  .thumbnail-wrap {
    position: relative;
    overflow: hidden;
    background: var(--muted);
    aspect-ratio: 3 / 2;
    flex-shrink: 0;
  }

  @media (min-width: 640px) {
    .thumbnail-wrap {
      width: 200px;
      aspect-ratio: auto;
      align-self: stretch;
    }
  }

  .thumbnail-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 400ms cubic-bezier(0.25, 1, 0.5, 1);
  }

  .group:hover .thumbnail-img {
    transform: scale(1.04);
  }

  /* Text-Bereich: eigenes Padding */
  .card-text {
    flex: 1;
    padding: 20px 24px;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  /* Placeholder */
  .thumbnail-placeholder {
    width: 100%;
    height: 100%;
    min-height: 120px;
    background:
      radial-gradient(ellipse 80% 80% at 20% 30%, color-mix(in oklch, var(--mesh-warm) 60%, transparent) 0%, transparent 70%),
      radial-gradient(ellipse 60% 60% at 80% 70%, color-mix(in oklch, var(--mesh-cool) 50%, transparent) 0%, transparent 65%),
      var(--muted);
  }
</style>
