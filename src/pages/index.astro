---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { Card, CardContent, CardHeader, CardTitle, CardDescription } from '@/components/ui/card';
import { Badge } from '@/components/ui/badge';
import { Kbd } from '@/components/ui/kbd';
import { Button } from '@/components/ui/button';
import { UserAvatar } from '@/components/UserAvatar';
import { Separator } from '@/components/ui/separator';
import { getCollection } from 'astro:content';
import HeroMesh from '@/components/astro/HeroMesh.astro';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const latestPosts = allPosts
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);

const allProjects = await getCollection('projects');
const featuredProjects = allProjects
  .filter((p) => p.data.featured)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const formatDate = (date: Date) =>
  new Intl.DateTimeFormat('de-DE', { year: 'numeric', month: 'short' }).format(date);
---

<BaseLayout>
  <!-- Hero -->
  <section
    class="relative min-h-screen flex flex-col px-6 pt-32 pb-24"
    data-scroll="depth"
  >
    <HeroMesh />

    <div class="relative z-10 max-w-5xl mx-auto w-full flex flex-col justify-center flex-1">
      <!-- Top row: label + counter -->
      <div class="flex items-center justify-between mb-16">
        <span class="t-label text-muted-foreground">UI Designer &amp; Frontend Developer</span>
        <span class="t-label text-muted-foreground tabular-nums">2025</span>
      </div>

      <!-- Headline -->
      <h1 class="t-hero mb-8 max-w-4xl" data-reveal="words">
        Interfaces die man spürt, bevor man sie versteht.
      </h1>

      <!-- Divider -->
      <div class="w-full h-px bg-border mb-8"></div>

      <!-- Lead + CTA row -->
      <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-8">
        <p class="t-lead text-muted-foreground max-w-lg" data-reveal="words">
          Ich gestalte und baue digitale Produkte mit Fokus auf
          Typografie, Bewegung und Interaktion.
        </p>
        <div class="flex items-center gap-4 shrink-0">
          <Button data-magnetic data-cursor="button" client:visible>
            <a href="/projects" class="no-underline">Projekte ansehen</a>
          </Button>
          <a
            href="/blog"
            class="t-small text-muted-foreground hover:text-foreground transition-colors duration-200 underline underline-offset-4"
            data-cursor="link"
          >
            Blog lesen
          </a>
        </div>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 opacity-30">
      <div class="w-px h-10 bg-foreground origin-top scroll-indicator"></div>
    </div>
  </section>

  <!-- About Section -->
  <section class="px-6 py-24 border-t border-border">
    <div class="max-w-5xl mx-auto">
      <div class="grid lg:grid-cols-[1fr_2fr] gap-12 items-start" data-scroll="fade-up">
        <div class="flex flex-col gap-6">
          <UserAvatar className="size-24 lg:size-32" src="/avatar.jpg" alt="Patrick Schrödter" fallback="PS" client:visible />
          <h2 class="t-h2 max-w-[12ch]">I don’t just draw interfaces. I build systems.</h2>
        </div>
        
        <div class="flex flex-col gap-8">
          <div class="flex flex-col gap-6">
            <p class="t-body text-muted-foreground">
              Seit über <Kbd client:visible className="h-auto py-0.5 px-2 align-baseline font-mono text-sm font-normal rounded-md border border-border/50 shadow-sm">15 Jahren</Kbd> gestalte ich digitale Produkte an der Schnittstelle von Design und Code. Mein Weg führte mich von der klassischen Systemadministration über High-Growth E-Commerce (DefShop) und Corporate Innovation (Oetker Digital) bis hin zum Aufbau komplexer B2B-Plattformen und Super-Apps.
            </p>
            
            <p class="t-body text-muted-foreground">
              Ich bezeichne mich selbst gerne als <Kbd client:visible className="h-auto py-0.5 px-2 align-baseline font-mono text-sm font-normal rounded-md border border-border/50 shadow-sm">Design Engineer</Kbd>. Warum? Weil ich die Sprache der Entwickler spreche. Ob ich skalierbare Design-Systeme auf Basis von shadcn/ui und Tailwind CSS entwerfe oder repetitive Design-Ops durch n8n und <Kbd client:visible className="h-auto py-0.5 px-2 align-baseline font-mono text-sm font-normal rounded-md border border-border/50 shadow-sm">KI-Workflows</Kbd> (Claude/Gemini CLI) automatisiere – mein Ziel ist immer ein nahtloser Übergang vom Pixel zum produktiven Code.
            </p>

            <p class="t-body text-muted-foreground">
              Ich glaube fest an die Kraft der physischen Zusammenarbeit. Deshalb findet man mich meistens direkt im <Kbd client:visible className="h-auto py-0.5 px-2 align-baseline font-mono text-sm font-normal rounded-md border border-border/50 shadow-sm">Berliner Office</Kbd>, wo ich am liebsten in cross-funktionalen Teams komplexe Workflows in intuitive Erlebnisse verwandele.
            </p>
          </div>

          <Separator client:visible />

          <div class="grid md:grid-cols-2 gap-8">
            <div class="flex flex-col gap-4">
              <h3 class="t-label text-foreground">Was mich antreibt?</h3>
              <p class="t-body text-muted-foreground">
                Optimierung. Wenn ein Prozess effizienter, ein System logischer oder ein Interface menschlicher werden kann, bin ich in meinem Element. In meiner Freizeit schraube ich an meinem Proxmox-basierten Homelab oder experimentiere mit Agentic Workflows – immer auf der Suche nach dem nächsten Hebel für besseres Produktdesign.
              </p>
            </div>
            <div class="flex items-end">
              <p class="t-body font-bold text-foreground">
                Du suchst jemanden, der Ownership übernimmt und Design als technisches Handwerk versteht? Lass uns in Berlin auf einen Kaffee treffen.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Latest Blog Posts -->
  {latestPosts.length > 0 && (
    <section class="px-6 py-24">
      <div class="max-w-5xl mx-auto">
        <div class="flex items-baseline justify-between mb-12">
          <h2 class="t-h2">Zuletzt geschrieben</h2>
          <a
            href="/blog"
            class="t-small text-muted-foreground hover:text-foreground transition-colors duration-200 underline underline-offset-4"
            data-cursor="link"
          >
            Alle Posts
          </a>
        </div>
        <div class="grid gap-4">
          {latestPosts.map((post) => (
            <a href={`/blog/${post.id.replace(/\.md$/, '')}`} class="group block no-underline" data-cursor="link">
              <Card
                data-scroll="fade-up"
                client:visible
                className="transition-all duration-300 group-hover:border-foreground/20 group-hover:bg-muted/50"
              >
                <CardHeader>
                  <div class="flex items-start justify-between gap-4">
                    <div class="flex-1">
                      <CardTitle className="t-h3 mb-2">
                        {post.data.title}
                      </CardTitle>
                      <CardDescription className="t-body text-muted-foreground">
                        {post.data.description}
                      </CardDescription>
                    </div>
                    <time class="t-label text-muted-foreground shrink-0 mt-1">
                      {formatDate(post.data.date)}
                    </time>
                  </div>
                  {post.data.tags && post.data.tags.length > 0 && (
                    <div class="flex flex-wrap gap-2 mt-4">
                      {post.data.tags.map((tag) => (
                        <Badge variant="secondary" client:visible>{tag}</Badge>
                      ))}
                    </div>
                  )}
                </CardHeader>
              </Card>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Featured Projects -->
  {featuredProjects.length > 0 && (
    <section class="px-6 py-24 border-t border-border">
      <div class="max-w-5xl mx-auto">
        <div class="flex items-baseline justify-between mb-12">
          <h2 class="t-h2">Ausgewählte Projekte</h2>
          <a
            href="/projects"
            class="t-small text-muted-foreground hover:text-foreground transition-colors duration-200 underline underline-offset-4"
            data-cursor="link"
          >
            Alle Projekte
          </a>
        </div>
        <div class="grid md:grid-cols-2 gap-6">
          {featuredProjects.map((project) => (
            <a href={`/projects/${project.id.replace(/\.md$/, '')}`} class="group block no-underline" data-cursor="link">
              <Card
                data-scroll="fade-up"
                client:visible
                className="h-full transition-all duration-300 group-hover:border-foreground/20 group-hover:bg-muted/50"
              >
                <CardHeader>
                  <CardTitle className="t-h3 mb-2">
                    {project.data.title}
                  </CardTitle>
                  <CardDescription className="t-body text-muted-foreground">
                    {project.data.description}
                  </CardDescription>
                </CardHeader>
                <CardContent>
                  <div class="flex flex-wrap gap-2">
                    {project.data.tags.map((tag) => (
                      <Badge variant="outline" client:visible>{tag}</Badge>
                    ))}
                  </div>
                </CardContent>
              </Card>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}
</BaseLayout>

<style>
  .scroll-indicator {
    animation: scroll-line 2s ease-in-out infinite;
  }

  @keyframes scroll-line {
    0%, 100% { transform: scaleY(0); opacity: 0; }
    50% { transform: scaleY(1); opacity: 1; }
  }

  @media (prefers-reduced-motion: reduce) {
    .scroll-indicator {
      animation: none;
    }
  }
</style>
