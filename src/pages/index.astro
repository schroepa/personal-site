---
import BaseLayout from "@/layouts/BaseLayout.astro"
import {
  Card,
  CardContent,
  CardHeader,
  CardTitle,
  CardDescription,
} from "@/components/ui/card"
import { Badge } from "@/components/ui/badge"
import { Kbd } from "@/components/ui/kbd"
import { Button } from "@/components/ui/button"
import { UserAvatar } from "@/components/UserAvatar"
import { Separator } from "@/components/ui/separator"
import { getCollection } from "astro:content"
import { readingTime } from "@/lib/reading-time"
import HeroMesh from "@/components/astro/HeroMesh.astro"

const allPosts = await getCollection("blog", ({ data }) => !data.draft)
const latestPosts = allPosts
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3)

const allProjects = await getCollection("projects")
const featuredProjects = allProjects
  .filter((p) => p.data.featured)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())

const formatDate = (date: Date) =>
  new Intl.DateTimeFormat("de-DE", { year: "numeric", month: "short" }).format(
    date
  )
---

<BaseLayout>
  <!-- Hero -->
  <section
    class="hero-section relative flex flex-col px-6 pt-24 pb-24"
    data-scroll="depth"
  >
    <HeroMesh />

    <div
      class="relative z-10 mx-auto flex w-full max-w-5xl flex-1 flex-col justify-center"
    >
      <!-- Top row: label + counter -->
      <div class="mb-16 flex items-center justify-between">
        <span class="t-label text-muted-foreground"
          >UI Designer &amp; Frontend Developer</span
        >
        <span class="t-label text-muted-foreground tabular-nums">2025</span>
      </div>

      <!-- Headline -->
      <h1 class="t-hero mb-8 max-w-4xl" data-reveal="words">
        Interfaces die man spürt, bevor man sie versteht.
      </h1>

      <!-- Divider -->
      <div class="mb-8 h-px w-full bg-border"></div>

      <!-- Lead + CTA row -->
      <div
        class="flex flex-col gap-8 md:flex-row md:items-end md:justify-between"
      >
        <p class="t-lead max-w-lg text-muted-foreground" data-reveal="words">
          Ich gestalte und baue digitale Produkte mit Fokus auf Typografie,
          Bewegung und Interaktion.
        </p>
        <div class="flex shrink-0 items-center gap-4">
          <Button data-magnetic data-cursor="button" client:visible>
            <a href="/projects" class="no-underline">Projekte ansehen</a>
          </Button>
          <a
            href="/blog"
            class="t-small text-muted-foreground underline underline-offset-4 transition-colors duration-200 hover:text-foreground"
            data-cursor="link"
          >
            Blog lesen
          </a>
        </div>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div
      class="absolute bottom-8 left-1/2 flex -translate-x-1/2 flex-col items-center gap-2 opacity-30"
    >
      <div class="scroll-indicator h-10 w-px origin-top bg-foreground"></div>
    </div>
  </section>

  <!-- About Section -->
  <section class="border-t border-border px-6 py-24">
    <div class="mx-auto max-w-5xl">
      <div
        class="grid items-start gap-12 lg:grid-cols-[1fr_2fr]"
        data-scroll="fade-up"
      >
        <div class="flex flex-col gap-6">
          <UserAvatar
            className="size-24 lg:size-32"
            src="/avatar.jpg"
            alt="Patrick Schrödter"
            fallback="PS"
            client:visible
          />
          <h2 class="t-h2 max-w-[12ch]">
            I don’t just draw interfaces. I build systems.
          </h2>
        </div>

        <div class="flex flex-col gap-8">
          <div class="flex flex-col gap-6">
            <p class="t-body text-foreground">
              Seit über <Kbd
                client:visible
                className="h-auto rounded-md border border-border/50 px-2 py-0.5 align-baseline font-mono text-sm font-normal text-foreground"
                >15 Jahren</Kbd
              > gestalte ich digitale Produkte an der Schnittstelle von Design und
              Code. Mein Weg führte mich von der klassischen Systemadministration
              über High-Growth E-Commerce (DefShop) und Corporate Innovation (Oetker
              Digital) bis hin zum Aufbau komplexer B2B-Plattformen und Super-Apps.
            </p>

            <p class="t-body text-foreground">
              Ich bezeichne mich selbst gerne als <Kbd
                client:visible
                className="h-auto rounded-md border border-border/50 px-2 py-0.5 align-baseline font-mono text-sm font-normal text-foreground"
                >Design Engineer</Kbd
              >. Warum? Weil ich die Sprache der Entwickler spreche. Ob ich
              skalierbare Design-Systeme auf Basis von shadcn/ui und Tailwind
              CSS entwerfe oder repetitive Design-Ops durch n8n und <Kbd
                client:visible
                className="h-auto rounded-md border border-border/50 px-2 py-0.5 align-baseline font-mono text-sm font-normal text-foreground"
                >KI-Workflows</Kbd
              > (Claude/Gemini CLI) automatisiere – mein Ziel ist immer ein nahtloser
              Übergang vom Pixel zum produktiven Code.
            </p>

            <p class="t-body text-foreground">
              Ich glaube fest an die Kraft der physischen Zusammenarbeit.
              Deshalb findet man mich meistens direkt im <Kbd
                client:visible
                className="h-auto rounded-md border border-border/50 px-2 py-0.5 align-baseline font-mono text-sm font-normal text-foreground"
                >Berliner Office</Kbd
              >, wo ich am liebsten in cross-funktionalen Teams komplexe
              Workflows in intuitive Erlebnisse verwandele.
            </p>
          </div>

          <Separator client:visible />

          <div class="grid gap-8 md:grid-cols-2">
            <div class="flex flex-col gap-4">
              <h3 class="font-bold text-foreground">Was mich antreibt?</h3>
              <p class="t-body text-muted-foreground">
                Optimierung. Wenn ein Prozess effizienter, ein System logischer
                oder ein Interface menschlicher werden kann, bin ich in meinem
                Element. In meiner Freizeit schraube ich an meinem
                Proxmox-basierten Homelab oder experimentiere mit Agentic
                Workflows – immer auf der Suche nach dem nächsten Hebel für
                besseres Produktdesign.
              </p>
            </div>
            <div class="flex items-end">
              <p class="font-medium text-foreground">
                Du suchst jemanden, der Ownership übernimmt und Design als
                technisches Handwerk versteht? Lass uns in Berlin auf einen
                Kaffee treffen.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Latest Blog Posts -->
  <!-- Zuletzt geschrieben -->
  {latestPosts.length > 0 && (
    <section class="px-6 py-24">
      <div class="mx-auto max-w-5xl">
        <div class="hp-section-header">
          <h2 class="t-h2">Zuletzt geschrieben</h2>
          <a href="/blog" class="t-small text-muted-foreground underline underline-offset-4 transition-colors duration-200 hover:text-foreground" data-cursor="link">
            Alle Posts
          </a>
        </div>

        <div class="hp-post-grid">
          {latestPosts.map((post) => (
            <article class="hp-post-entry" data-scroll="fade-up">
              <a href={`/blog/${post.id.replace(/\.md$/, "")}`} class="hp-entry-link" data-cursor="link">
                <div class="hp-entry-image">
                  {post.data.coverImage
                    ? <img src={post.data.coverImage} alt="" loading="lazy" class="hp-entry-img" />
                    : <div class="hp-entry-fallback" aria-hidden="true"></div>
                  }
                </div>
                <div class="hp-entry-body">
                  <div class="hp-entry-meta">
                    <time datetime={post.data.date.toISOString()}>{formatDate(post.data.date)}</time>
                    <span>·</span>
                    <span>{readingTime(post.body ?? '')} min</span>
                  </div>
                  <h3 class="hp-entry-title">{post.data.title}</h3>
                  <p class="hp-entry-desc">{post.data.description}</p>
                </div>
              </a>
            </article>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Ausgewählte Projekte -->
  {featuredProjects.length > 0 && (
    <section class="px-6 py-24">
      <div class="mx-auto max-w-5xl">
        <div class="hp-section-header">
          <h2 class="t-h2">Ausgewählte Projekte</h2>
          <a href="/projects" class="t-small text-muted-foreground underline underline-offset-4 transition-colors duration-200 hover:text-foreground" data-cursor="link">
            Alle Projekte
          </a>
        </div>

        <div class="hp-project-grid">
          {featuredProjects.map((project) => (
            <article class="hp-project-entry" data-scroll="fade-up">
              <a href={`/projects/${project.id.replace(/\.md$/, "")}`} class="hp-entry-link" data-cursor="link">
                <div class="hp-entry-image">
                  {project.data.coverImage
                    ? <img src={project.data.coverImage} alt="" loading="lazy" class="hp-entry-img" />
                    : <div class="hp-entry-fallback" aria-hidden="true"></div>
                  }
                </div>
                <div class="hp-entry-body">
                  <div class="hp-entry-meta">
                    <time datetime={project.data.date.toISOString()}>{formatDate(project.data.date)}</time>
                  </div>
                  <h3 class="hp-entry-title">{project.data.title}</h3>
                  <p class="hp-entry-desc">{project.data.description}</p>
                  <div class="hp-entry-tags">
                    {project.data.tags.slice(0, 3).map(tag => (
                      <Badge variant="secondary" client:visible>{tag}</Badge>
                    ))}
                  </div>
                </div>
              </a>
            </article>
          ))}
        </div>
      </div>
    </section>
  )}
</BaseLayout>

<style>
  .hero-section {
    height: 100vh;
    max-height: 100vh;
  }

  @media (max-width: 767px) {
    .hero-section {
      height: auto;
      min-height: 60dvh;
      max-height: none;
    }
  }

  .scroll-indicator {
    animation: scroll-line 2s ease-in-out infinite;
  }

  @keyframes scroll-line {
    0%,
    100% {
      transform: scaleY(0);
      opacity: 0;
    }
    50% {
      transform: scaleY(1);
      opacity: 1;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .scroll-indicator { animation: none; }
    .hp-entry-img { transition: none; }
  }

  /* ── Homepage Sektionen ─────────────────────────────────────────────────── */
  .hp-section-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 3rem;
  }

  /* Letzten Posts: 3-spaltig auf Desktop */
  .hp-post-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0;
  }

  @media (min-width: 768px) {
    .hp-post-grid {
      grid-template-columns: repeat(3, 1fr);
      column-gap: 3rem;
    }
  }

  .hp-post-entry {
    padding-bottom: 2.5rem;
    margin-bottom: 2.5rem;
    border-bottom: 1px solid color-mix(in oklch, var(--foreground) 12%, transparent);
  }

  @media (min-width: 768px) {
    .hp-post-entry {
      border-bottom: none;
      padding-bottom: 0;
      margin-bottom: 0;
    }
  }

  /* Projekte: 2-spaltig auf Desktop */
  .hp-project-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0;
  }

  @media (min-width: 768px) {
    .hp-project-grid {
      grid-template-columns: 1fr 1fr;
      column-gap: 4rem;
    }
  }

  .hp-project-entry {
    padding-bottom: 3rem;
    margin-bottom: 3rem;
    border-bottom: 1px solid color-mix(in oklch, var(--foreground) 12%, transparent);
  }

  .hp-project-entry:last-child {
    border-bottom: none;
    margin-bottom: 0;
  }

  /* Gemeinsame Entry-Styles */
  .hp-entry-link {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  .hp-entry-image {
    width: 100%;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    margin-bottom: 1rem;
  }

  .hp-entry-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 600ms cubic-bezier(0.25, 1, 0.5, 1);
  }

  .hp-entry-link:hover .hp-entry-img {
    transform: scale(1.03);
  }

  .hp-entry-fallback {
    width: 100%;
    height: 100%;
    background:
      radial-gradient(ellipse 80% 80% at 20% 30%,
        color-mix(in oklch, var(--mesh-warm) 50%, transparent) 0%, transparent 70%),
      radial-gradient(ellipse 60% 60% at 80% 70%,
        color-mix(in oklch, var(--mesh-cool) 40%, transparent) 0%, transparent 65%),
      var(--muted);
  }

  .hp-entry-body {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .hp-entry-meta {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    font-weight: 500;
    color: var(--muted-foreground);
  }

  .hp-entry-title {
    font-size: var(--text-base);
    font-weight: 500;
    line-height: var(--leading-snug);
    letter-spacing: var(--tracking-snug);
    color: var(--foreground);
    margin: 0.125rem 0 0;
    transition: opacity 200ms ease;
  }

  .hp-entry-link:hover .hp-entry-title {
    opacity: 0.6;
  }

  .hp-entry-desc {
    font-size: var(--text-sm);
    line-height: var(--leading-normal);
    color: var(--muted-foreground);
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .hp-entry-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
    margin-top: 0.25rem;
  }
</style>
