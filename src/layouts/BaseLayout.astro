---
import { ViewTransitions } from "astro:transitions"
import CustomCursor from "@/components/astro/CustomCursor.astro"
import GrainOverlay from "@/components/astro/GrainOverlay.astro"
import BaselineGrid from "@/components/astro/BaselineGrid.astro"
import "@/styles/global.css"
import "@/styles/typography.css"
import "@/styles/animations.css"
import "@/styles/prose.css"

interface Props {
  title?: string
  description?: string
  ogImage?: string
  ogType?: 'website' | 'article'
  canonicalURL?: string
  articleDate?: Date
  articleAuthor?: string
  articleTags?: string[]
}

const {
  title = "Patrick Schröder — UI Designer & Developer",
  description = "Personal site of Patrick Schröder, UI Designer and Frontend Developer.",
  ogImage,
  ogType = 'website',
  canonicalURL = Astro.url.href,
  articleDate,
  articleAuthor,
  articleTags = [],
} = Astro.props

const siteName = "ptrckschrdtr.de"
const siteUrl  = "https://ptrckschrdtr.de"
const ogImageURL = ogImage
  ? new URL(ogImage, siteUrl).toString()
  : `${siteUrl}/og-default.png`

// OG-Bildgröße: Cover-Images sind 2100×900, Default ist 1920×1080
const ogImageWidth  = ogImage ? 2100 : 1920
const ogImageHeight = ogImage ? 900  : 1080

const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: "Patrick Schröder",
  url: siteUrl,
  jobTitle: "UI Designer & Frontend Developer",
  sameAs: [
    // "[PLACEHOLDER: GitHub URL]",
    // "[PLACEHOLDER: LinkedIn URL]",
  ],
}

const navLinks = [
  { href: "/", label: "Start" },
  { href: "/blog", label: "Blog" },
  { href: "/projects", label: "Projekte" },
]
---

<!doctype html>
<html lang="de" class="overflow-x-hidden scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <!-- Primary -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type"         content={ogType} />
    <meta property="og:url"          content={canonicalURL} />
    <meta property="og:site_name"    content={siteName} />
    <meta property="og:title"        content={title} />
    <meta property="og:description"  content={description} />
    <meta property="og:image"        content={ogImageURL} />
    <meta property="og:image:width"  content={String(ogImageWidth)} />
    <meta property="og:image:height" content={String(ogImageHeight)} />
    <meta property="og:image:alt"    content={title} />
    <meta property="og:locale"       content="de_DE" />
    <meta property="og:logo"         content={`${siteUrl}/favicon.svg`} />

    <!-- Article-spezifische OG-Tags (nur bei og:type="article") -->
    {ogType === 'article' && articleDate && (
      <meta property="article:published_time" content={articleDate.toISOString()} />
    )}
    {ogType === 'article' && articleAuthor && (
      <meta property="article:author" content={articleAuthor} />
    )}
    {ogType === 'article' && articleTags.map(tag => (
      <meta property="article:tag" content={tag} />
    ))}

    <!-- Twitter / X Card -->
    <meta name="twitter:card"        content="summary_large_image" />
    <meta name="twitter:title"       content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image"       content={ogImageURL} />
    <meta name="twitter:image:alt"   content={title} />

    <!-- JSON-LD -->
    <script type="application/ld+json" set:html={JSON.stringify(personSchema)} />

    <ViewTransitions />
  </head>
  <body
    class="relative min-h-screen overflow-x-hidden bg-background text-foreground antialiased"
  >
    <CustomCursor />
    <GrainOverlay />
    <BaselineGrid />

    <!-- Header -->
    <header
      class="fixed top-0 right-0 left-0 z-50 border-b border-foreground/5 bg-background/50 px-6 py-5 shadow-[0_8px_30px_rgb(0,0,0,0.04)] backdrop-blur-2xl backdrop-saturate-200 supports-[backdrop-filter]:bg-background/40"
    >
      <nav class="mx-auto flex max-w-5xl items-center justify-between">
        <a
          href="/"
          class="font-medium text-foreground no-underline transition-opacity duration-200 hover:opacity-60"
          data-magnetic
          data-cursor="link"
        >
          PTRCKSCHRDTR
        </a>
        <ul class="m-0 flex list-none items-center gap-8 p-0">
          {
            navLinks.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-muted-foreground no-underline transition-colors duration-200 hover:text-foreground"
                  data-magnetic
                  data-cursor="link"
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>
    </header>

    <!-- Main content -->
    <main>
      <slot />
    </main>

    <!-- Footer -->
    <footer class="mt-24 border-t border-border px-6 py-12">
      <div class="mx-auto flex max-w-5xl items-center justify-between gap-8 flex-wrap">
        <span class="t-small text-muted-foreground">
          © {new Date().getFullYear()} Patrick Schröder
        </span>
        <nav aria-label="Rechtliches" class="flex items-center gap-6">
          <a
            href="/impressum"
            class="t-small text-muted-foreground no-underline transition-colors duration-200 hover:text-foreground"
            data-cursor="link"
          >
            Impressum
          </a>
          <a
            href="/datenschutz"
            class="t-small text-muted-foreground no-underline transition-colors duration-200 hover:text-foreground"
            data-cursor="link"
          >
            Datenschutz
          </a>
        </nav>
      </div>
    </footer>

    <script>
      import { initMagneticButtons } from "@/scripts/magnetic"
      import { initTextReveal } from "@/scripts/textReveal"
      import { initScrollAnimations } from "@/scripts/scrollAnimations"

      document.addEventListener("astro:page-load", () => {
        initMagneticButtons()
        initTextReveal()
        initScrollAnimations()
      })
    </script>
  </body>
</html>
