---
import { ViewTransitions } from "astro:transitions"
import CustomCursor from "@/components/astro/CustomCursor.astro"
import GrainOverlay from "@/components/astro/GrainOverlay.astro"
import BaselineGrid from "@/components/astro/BaselineGrid.astro"
import "@/styles/global.css"
import "@/styles/typography.css"
import "@/styles/animations.css"
import "@/styles/prose.css"

interface Props {
  title?: string
  description?: string
  ogImage?: string
  ogType?: 'website' | 'article'
  canonicalURL?: string
  articleDate?: Date
  articleAuthor?: string
  articleTags?: string[]
}

const {
  title = "Patrick Schröder — UI Designer & Developer",
  description = "Personal site of Patrick Schröder, UI Designer and Frontend Developer.",
  ogImage,
  ogType = 'website',
  canonicalURL = Astro.url.href,
  articleDate,
  articleAuthor,
  articleTags = [],
} = Astro.props

const siteName = "ptrckschrdtr.de"
const siteUrl  = "https://ptrckschrdtr.de"
const ogImageURL = ogImage
  ? new URL(ogImage, siteUrl).toString()
  : `${siteUrl}/og-default.png`

// OG-Bildgröße: Cover-Images sind 2100×900, Default ist 1920×1080
const ogImageWidth  = ogImage ? 2100 : 1920
const ogImageHeight = ogImage ? 900  : 1080

const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: "Patrick Schröder",
  url: siteUrl,
  jobTitle: "UI Designer & Frontend Developer",
  sameAs: [
    // "[PLACEHOLDER: GitHub URL]",
    // "[PLACEHOLDER: LinkedIn URL]",
  ],
}

const navLinks = [
  { href: "/", label: "Start" },
  { href: "/about", label: "Über" },
  { href: "/blog", label: "Blog" },
  { href: "/projects", label: "Projekte" },
]
---

<!doctype html>
<html lang="de" class="overflow-x-hidden scroll-smooth">
  <head>

    <!-- Google tag (gtag.js) -->
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-3SFN6YV6W9"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-3SFN6YV6W9');
    </script>

    <!-- Google Tag Manager -->
    <script is:inline>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
    new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
    j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
    'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
    })(window,document,'script','dataLayer','GTM-T4HLWZWZ');</script>
    <!-- End Google Tag Manager -->

    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Primary -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type"         content={ogType} />
    <meta property="og:url"          content={canonicalURL} />
    <meta property="og:site_name"    content={siteName} />
    <meta property="og:title"        content={title} />
    <meta property="og:description"  content={description} />
    <meta property="og:image"        content={ogImageURL} />
    <meta property="og:image:width"  content={String(ogImageWidth)} />
    <meta property="og:image:height" content={String(ogImageHeight)} />
    <meta property="og:image:alt"    content={title} />
    <meta property="og:locale"       content="de_DE" />
    <meta property="og:logo"         content={`${siteUrl}/logo.svg`} />

    <!-- Article-spezifische OG-Tags (nur bei og:type="article") -->
    {ogType === 'article' && articleDate && (
      <meta property="article:published_time" content={articleDate.toISOString()} />
    )}
    {ogType === 'article' && articleAuthor && (
      <meta property="article:author" content={articleAuthor} />
    )}
    {ogType === 'article' && articleTags.map(tag => (
      <meta property="article:tag" content={tag} />
    ))}

    <!-- Twitter / X Card -->
    <meta property="twitter:card"        content="summary_large_image" />
    <meta property="twitter:title"       content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image"       content={ogImageURL} />
    <meta property="twitter:image:alt"   content={title} />

    <!-- JSON-LD -->
    <script type="application/ld+json" set:html={JSON.stringify(personSchema)} />

    <ViewTransitions />
  </head>
  <body
    class="relative min-h-screen overflow-x-hidden bg-background text-foreground antialiased"
  >
  <!-- Google Tag Manager (noscript) -->
  <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-T4HLWZWZ"
  height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
  <!-- End Google Tag Manager (noscript) -->
    <CustomCursor />
    <GrainOverlay />
    <BaselineGrid />

    <!-- Header -->
    <header
      class="fixed top-0 right-0 left-0 z-[60] bg-background/50 px-6 py-5 shadow-[0_8px_30px_rgb(0,0,0,0.04)] backdrop-blur-2xl backdrop-saturate-200 supports-[backdrop-filter]:bg-background/40"
    >
      <nav class="mx-auto flex max-w-5xl items-center justify-between">
        <a
          href="/"
          class="font-medium text-foreground no-underline transition-opacity duration-200 hover:opacity-60 nav-logo"
          data-magnetic
          data-cursor="link"
        >
          PTRCKSCHRDTR
        </a>

        <!-- Desktop nav -->
        <ul class="nav-desktop m-0 flex list-none items-center gap-8 p-0">
          {
            navLinks.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-muted-foreground no-underline transition-colors duration-200 hover:text-foreground"
                  data-magnetic
                  data-cursor="link"
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>

        <!-- Hamburger (mobile only) -->
        <button
          id="nav-toggle"
          class="nav-toggle"
          aria-label="Menü öffnen"
          aria-expanded="false"
          aria-controls="nav-overlay"
        >
          <span class="bar bar-1"></span>
          <span class="bar bar-2"></span>
          <span class="bar bar-3"></span>
        </button>
      </nav>
    </header>

    <!-- Full-Screen Overlay -->
    <div id="nav-overlay" class="nav-overlay" aria-hidden="true" role="dialog" aria-label="Navigation">
      <nav class="nav-overlay-links">
        {navLinks.map((link, i) => (
          <a
            href={link.href}
            class="nav-overlay-link"
            style={`--i: ${i}`}
            data-cursor="link"
          >
            {link.label}
          </a>
        ))}
      </nav>
      <div class="nav-overlay-footer">
        <a href="/impressum" class="nav-overlay-small">Impressum</a>
        <a href="/datenschutz" class="nav-overlay-small">Datenschutz</a>
      </div>
    </div>

    <!-- Main content -->
    <main>
      <slot />
    </main>

    <!-- Footer -->
    <footer class="mt-24 px-6 py-12">
      <div class="mx-auto flex max-w-5xl items-center justify-between gap-8 flex-wrap">
        <span class="t-small text-muted-foreground">
          © {new Date().getFullYear()} Patrick Schröder
        </span>
        <nav aria-label="Rechtliches" class="flex items-center gap-6">
          <a
            href="/impressum"
            class="t-small text-muted-foreground no-underline transition-colors duration-200 hover:text-foreground"
            data-cursor="link"
          >
            Impressum
          </a>
          <a
            href="/datenschutz"
            class="t-small text-muted-foreground no-underline transition-colors duration-200 hover:text-foreground"
            data-cursor="link"
          >
            Datenschutz
          </a>
        </nav>
      </div>
    </footer>

    <script>
      import { initMagneticButtons } from "@/scripts/magnetic"
      import { initTextReveal } from "@/scripts/textReveal"
      import { initScrollAnimations } from "@/scripts/scrollAnimations"

      document.addEventListener("astro:page-load", () => {
        initMagneticButtons()
        initTextReveal()
        initScrollAnimations()
        initHamburger()
      })

      function initHamburger() {
        const toggle  = document.getElementById('nav-toggle')  as HTMLButtonElement | null
        const overlay = document.getElementById('nav-overlay') as HTMLElement | null
        if (!toggle || !overlay) return

        function open() {
          toggle!.classList.add('is-open')
          overlay!.classList.add('is-open')
          toggle!.setAttribute('aria-expanded', 'true')
          overlay!.setAttribute('aria-hidden', 'false')
          document.body.style.overflow = 'hidden'
        }

        function close() {
          toggle!.classList.remove('is-open')
          overlay!.classList.remove('is-open')
          toggle!.setAttribute('aria-expanded', 'false')
          overlay!.setAttribute('aria-hidden', 'true')
          document.body.style.overflow = ''
        }

        toggle.addEventListener('click', () => {
          toggle.classList.contains('is-open') ? close() : open()
        })

        overlay.querySelectorAll('a').forEach(link => {
          link.addEventListener('click', close)
        })

        document.addEventListener('keydown', (e) => {
          if (e.key === 'Escape') close()
        })
      }
    </script>

    <style>
      /* ── Hamburger Icon ─────────────────────────────────────────────────── */
      .nav-toggle {
        display: none;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        gap: 5px;
        width: 36px;
        height: 36px;
        background: none;
        border: none;
        cursor: pointer;
        z-index: 70;
        position: relative;
        padding: 0;
      }

      .bar {
        display: block;
        width: 22px;
        height: 1.5px;
        background: var(--foreground);
        transform-origin: center;
        transition:
          transform 280ms cubic-bezier(0.16, 1, 0.3, 1),
          opacity   220ms cubic-bezier(0.16, 1, 0.3, 1),
          background 200ms ease;
      }

      .nav-toggle.is-open .bar { background: var(--background); }
      .nav-toggle.is-open .bar-1 { transform: translateY(6.5px) rotate(45deg); }
      .nav-toggle.is-open .bar-2 { opacity: 0; transform: scaleX(0); }
      .nav-toggle.is-open .bar-3 { transform: translateY(-6.5px) rotate(-45deg); }

      /* ── Full-Screen Overlay ────────────────────────────────────────────── */
      .nav-overlay {
        position: fixed;
        inset: 0;
        z-index: 55;
        background: var(--foreground);
        display: flex;
        flex-direction: column;
        justify-content: center;
        padding: 6rem 2.5rem 3rem;
        opacity: 0;
        pointer-events: none;
        transition: opacity 300ms cubic-bezier(0.16, 1, 0.3, 1);
      }

      .nav-overlay.is-open {
        opacity: 1;
        pointer-events: auto;
      }

      .nav-overlay-links {
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
      }

      .nav-overlay-link {
        font-size: var(--text-3xl);
        font-weight: 500;
        line-height: var(--leading-tight);
        letter-spacing: var(--tracking-tight);
        color: var(--background);
        text-decoration: none;
        opacity: 0;
        transform: translateY(18px);
        transition:
          opacity  500ms cubic-bezier(0.16, 1, 0.3, 1),
          transform 500ms cubic-bezier(0.16, 1, 0.3, 1),
          color 150ms ease;
        transition-delay: calc(var(--i) * 70ms + 80ms);
      }

      .nav-overlay-link:hover { color: color-mix(in oklch, var(--background) 60%, transparent); }

      .nav-overlay.is-open .nav-overlay-link {
        opacity: 1;
        transform: translateY(0);
      }

      .nav-overlay-footer {
        position: absolute;
        bottom: 2.5rem;
        left: 2.5rem;
        display: flex;
        gap: 1.5rem;
        opacity: 0;
        transition: opacity 400ms ease;
        transition-delay: 300ms;
      }

      .nav-overlay.is-open .nav-overlay-footer { opacity: 1; }

      .nav-overlay-small {
        font-size: var(--text-xs);
        letter-spacing: var(--tracking-wide);
        text-transform: uppercase;
        color: color-mix(in oklch, var(--background) 40%, transparent);
        text-decoration: none;
        transition: color 150ms ease;
      }
      .nav-overlay-small:hover { color: var(--background); }

      /* ── Responsive: Hamburger nur auf Mobile ───────────────────────────── */
      @media (max-width: 767px) {
        .nav-toggle  { display: flex; }
        .nav-desktop { display: none; }
      }

      @media (prefers-reduced-motion: reduce) {
        .bar, .nav-overlay, .nav-overlay-link, .nav-overlay-footer {
          transition: none !important;
        }
      }
    </style>
  </body>
</html>
