---
import { ViewTransitions } from "astro:transitions"
import CustomCursor from "@/components/astro/CustomCursor.astro"
import PostHog from "@/components/posthog.astro"
import "@/styles/global.css"
import "@/styles/typography.css"
import "@/styles/animations.css"
import "@/styles/prose.css"

interface Props {
  title?: string
  description?: string
  ogImage?: string
  ogType?: "website" | "article"
  canonicalURL?: string
  articleDate?: Date
  articleAuthor?: string
  articleTags?: string[]
}

const {
  title = "Patrick Schröder — UI Designer & Developer",
  description = "Personal site of Patrick Schröder, UI Designer and Frontend Developer.",
  ogImage,
  ogType = "website",
  canonicalURL = Astro.url.href,
  articleDate,
  articleAuthor,
  articleTags = [],
} = Astro.props

const siteName = "ptrckschrdtr.de"
const siteUrl = "https://ptrckschrdtr.de"
const ogImageURL = ogImage
  ? new URL(ogImage, siteUrl).toString()
  : `${siteUrl}/og-default.png`

// OG-Bildgröße: Post-Cover werden als 1200×630-Halbton-Bild vorgerendert
// (siehe scripts/generate-og-images.mjs), Default ist 1920×1080
const ogImageWidth = ogImage ? 1200 : 1920
const ogImageHeight = ogImage ? 630 : 1080

const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: "Patrick Schröder",
  url: siteUrl,
  jobTitle: "UI Designer & Frontend Developer",
  sameAs: [
    // "[PLACEHOLDER: GitHub URL]",
    // "[PLACEHOLDER: LinkedIn URL]",
  ],
}

const navLinks = [
  { href: "/", label: "Start" },
  { href: "/about", label: "Über" },
  { href: "/blog", label: "Blog" },
  { href: "/projects", label: "Projekte" },
]

// ── Social Links — hier updaten ───────────────────────────────────────────
const social = {
  linkedin: "https://linkedin.com/in/ptrckschrdtr", // ← URL eintragen
  instagram: "https://instagram.com/ptrckschrdtr", // ← URL eintragen
  github: "https://github.com/ptrckschrdtr", // ← URL eintragen
}
// ── E-Mail (Bot-Schutz: kein mailto im HTML) ─────────────────────────────
const email = { user: "kontakt", domain: "ptrckschrdtr.de" }
---

<!doctype html>
<html lang="de" class="overflow-x-hidden scroll-smooth">
  <head>
    <!-- Google Consent Mode v2: Defaults ZUERST, vor allem anderen -->
    <script is:inline>
      window.dataLayer = window.dataLayer || []
      function gtag() { dataLayer.push(arguments) }

      gtag('consent', 'default', {
        ad_storage:             'denied',
        ad_user_data:           'denied',
        ad_personalization:     'denied',
        analytics_storage:      'denied',
        functionality_storage:  'denied',
        personalization_storage:'denied',
        security_storage:       'granted',
        wait_for_update:        500
      })

      gtag('set', 'ads_data_redaction', true)
      gtag('set', 'url_passthrough', false)
    </script>
    <!-- Cookiebot ZUERST — blockiert alle anderen Scripts bis Consent -->
    <script
      id="Cookiebot"
      src="https://consent.cookiebot.com/uc.js"
      data-cbid="302ab2a4-6e4a-43b3-82b6-f1d58c3f19f8"
      data-blockingmode="auto"
      type="text/javascript"
      is:inline
    ></script>
    <!-- Dark-Mode: FOUC-Prevention — synchron vor dem ersten Paint ──────── -->
    <script is:inline>
      ;(function () {
        const stored = localStorage.getItem("theme")
        const prefersDark = window.matchMedia(
          "(prefers-color-scheme: dark)"
        ).matches
        if (stored === "dark" || (!stored && prefersDark)) {
          document.documentElement.classList.add("dark")
        }
      })()
    </script>

    <!-- Google tag (gtag.js) -->
    <script
      is:inline
      async
      src="https://www.googletagmanager.com/gtag/js?id=G-3SFN6YV6W9"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || []
      function gtag() {
        dataLayer.push(arguments)
      }
      gtag("js", new Date())
      gtag("config", "G-3SFN6YV6W9")
    </script>

    <!-- Google Tag Manager -->
    <script is:inline>
      ;(function (w, d, s, l, i) {
        w[l] = w[l] || []
        w[l].push({ "gtm.start": new Date().getTime(), event: "gtm.js" })
        var f = d.getElementsByTagName(s)[0],
          j = d.createElement(s),
          dl = l != "dataLayer" ? "&l=" + l : ""
        j.async = true
        j.src = "https://www.googletagmanager.com/gtm.js?id=" + i + dl
        f.parentNode.insertBefore(j, f)
      })(window, document, "script", "dataLayer", "GTM-T4HLWZWZ")
    </script>
    <!-- End Google Tag Manager -->

    <meta charset="UTF-8" />
    <!-- Fonts: Fontsource-CSS aus dem Bundle nehmen — Vite löst url(./files/…) dort nicht zuverlässig auf (Build-Warnungen / Risiko abgebrochener Builds). Gleiche npm-Versionen wie zuvor, ausgeliefert über jsDelivr. -->
    <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/@fontsource-variable/geist@5.2.8/index.css"
      crossorigin="anonymous"
    />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/@fontsource/geist-mono@5.2.7/index.css"
      crossorigin="anonymous"
    />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Primary -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:image:width" content={String(ogImageWidth)} />
    <meta property="og:image:height" content={String(ogImageHeight)} />
    <meta property="og:image:alt" content={title} />
    <meta property="og:locale" content="de_DE" />
    <meta property="og:logo" content={`${siteUrl}/logo.svg`} />

    <!-- Article-spezifische OG-Tags (nur bei og:type="article") -->
    {
      ogType === "article" && articleDate && (
        <meta
          property="article:published_time"
          content={articleDate.toISOString()}
        />
      )
    }
    {
      ogType === "article" && articleAuthor && (
        <meta property="article:author" content={articleAuthor} />
      )
    }
    {
      ogType === "article" &&
        articleTags.map((tag) => <meta property="article:tag" content={tag} />)
    }

    <!-- Twitter / X Card -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={ogImageURL} />
    <meta property="twitter:image:alt" content={title} />

    <!-- JSON-LD -->
    <script
      type="application/ld+json"
      set:html={JSON.stringify(personSchema)}
    />

    <ViewTransitions />
    <PostHog />
  </head>
  <body
    class="relative min-h-screen overflow-x-hidden bg-background text-foreground antialiased"
  >
    <a href="#main-content" class="skip-link">Zum Inhalt springen</a>
    <!-- Google Tag Manager (noscript) -->
    <noscript
      ><iframe
        src="https://www.googletagmanager.com/ns.html?id=GTM-T4HLWZWZ"
        height="0"
        width="0"
        style="display:none;visibility:hidden"></iframe></noscript
    >
    <!-- End Google Tag Manager (noscript) -->
    <CustomCursor />

    <!-- ── Corner: Logo oben links ──────────────────────────────────── -->
    <div class="corner-logo">
      <a
        href="/"
        class="corner-logo-link"
        data-magnetic
        data-cursor="link"
        aria-label="Startseite"
      >
        PTRCKSCHRDTR
      </a>
    </div>

    <!-- ── Corner: Navigation oben rechts (Desktop) ────────────────── -->
    <nav class="corner-nav" aria-label="Hauptnavigation">
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            class="corner-nav-link"
            data-cursor="link"
            aria-current={Astro.url.pathname === link.href ? "page" : undefined}
          >
            {link.label}
          </a>
        ))
      }
    </nav>

    <!-- ── Theme Toggle: unten links, fixiert ──────────────────────────── -->
    <button
      id="theme-toggle"
      class="theme-toggle"
      type="button"
      aria-label="Zu Dunkel-Modus wechseln"
    >
      <span id="theme-toggle-label">DUNKEL</span>
    </button>

    <!-- ── Hamburger (Mobile only) ───────────────────────────────────── -->
    <button
      id="nav-toggle"
      class="nav-toggle"
      aria-label="Menü öffnen"
      aria-expanded="false"
      aria-controls="nav-overlay"
    >
      <span class="bar bar-1"></span>
      <span class="bar bar-2"></span>
    </button>

    <!-- ── Mobile Overlay ───────────────────────────────────────────── -->
    <div
      id="nav-overlay"
      class="nav-overlay"
      aria-hidden="true"
      inert
      role="dialog"
      aria-label="Navigation"
    >
      <nav class="nav-overlay-links" aria-label="Mobile Navigation">
        {
          navLinks.map((link, i) => (
            <a
              href={link.href}
              class="nav-overlay-link"
              style={`--i: ${i}`}
              data-cursor="link"
              aria-current={
                Astro.url.pathname === link.href ? "page" : undefined
              }
            >
              {link.label}
            </a>
          ))
        }
      </nav>
      <div class="nav-overlay-footer">
        <a href="/impressum" class="nav-overlay-small">Impressum</a>
        <a href="/datenschutz" class="nav-overlay-small">Datenschutz</a>
        <button
          id="theme-toggle-mobile"
          type="button"
          class="nav-overlay-small"
          style="background:none;border:none;padding:0;cursor:pointer;"
        >
          <span id="theme-toggle-mobile-label">DUNKEL</span>
        </button>
      </div>
    </div>

    <!-- Main content -->
    <main id="main-content">
      <slot />
    </main>

    <!-- ── Footer ───────────────────────────────────────────────────────── -->
    <footer class="site-footer page-grid" aria-label="Seiten-Footer">
      <div class="footer-inner">
        <!-- Obere Zeile: Identität links / Social + E-Mail rechts -->
        <div class="footer-top">
          <div class="footer-identity">
            <span class="footer-name t-label">PTRCKSCHRDTR</span>
            <span class="footer-tagline t-small text-muted-foreground">
              Design Engineer — Berlin
            </span>
          </div>

          <nav class="footer-social" aria-label="Social Media">
            <a
              href={social.linkedin}
              target="_blank"
              rel="noopener noreferrer"
              class="footer-link"
              data-cursor="link"
              aria-label="LinkedIn Profil"
            >
              LinkedIn ↗
            </a>
            <a
              href={social.instagram}
              target="_blank"
              rel="noopener noreferrer"
              class="footer-link"
              data-cursor="link"
              aria-label="Instagram Profil"
            >
              Instagram ↗
            </a>
            <a
              href={social.github}
              target="_blank"
              rel="noopener noreferrer"
              class="footer-link"
              data-cursor="link"
              aria-label="GitHub Profil"
            >
              GitHub ↗
            </a>
            <!-- E-Mail: Bot-Schutz via JS — kein mailto im HTML-Quelltext -->
            <button
              class="footer-link footer-email"
              data-user={email.user}
              data-domain={email.domain}
              aria-label={`E-Mail: ${email.user}@${email.domain}`}
              type="button"
            >
              {email.user}@{email.domain}
            </button>
          </nav>
        </div>

        <!-- Untere Zeile: Copyright links / Rechtliches rechts -->
        <div class="footer-bottom">
          <span class="t-small text-muted-foreground">
            © {new Date().getFullYear()} Patrick Schröder
          </span>
          <nav class="footer-legal" aria-label="Rechtliches">
            <a href="/impressum" class="footer-link" data-cursor="link">Impressum</a>
            <span class="footer-sep" aria-hidden="true">·</span>
            <a href="/datenschutz" class="footer-link" data-cursor="link">Datenschutz</a>
            <span class="footer-sep" aria-hidden="true">·</span>
            <button
              type="button"
              class="footer-link"
              onclick="Cookiebot.renew()"
              data-cursor="link"
            >
              Cookie-Einstellungen
            </button>
          </nav>
        </div>
      </div>
    </footer>

    <script>
      import { initMagneticButtons } from "@/scripts/magnetic"
      import { initTextReveal } from "@/scripts/textReveal"
      import { initScrollAnimations } from "@/scripts/scrollAnimations"

      // Dark Mode über View Transitions hinweg erhalten:
      // Bevor Astro das neue Dokument einsetzt, .dark auf das eingehende übertragen.
      document.addEventListener("astro:before-swap", (e) => {
        const event = e as { newDocument: Document }
        if (document.documentElement.classList.contains("dark")) {
          event.newDocument.documentElement.classList.add("dark")
        }
      })

      // Navigation-Resilienz: fehlerhafte Browser-Extensions (Passwort-Manager,
      // Ad-Blocker etc.) können Klicks abfangen und die SPA-Navigation lahmlegen
      // ("message channel closed" Fehler — kommt aus der Extension, nicht von uns).
      // Da die Seite per ViewTransitions nie komplett neu lädt, bleibt ein einmal
      // kaputter Extension-Zustand über mehrere Klicks hinweg bestehen.
      // Fallback: Wenn sich die URL nach kurzer Zeit nicht ändert, erzwingen wir
      // eine harte Navigation — die ist robuster gegen hängende Extension-Promises.
      document.addEventListener("click", (e) => {
        const link = (e.target as HTMLElement)?.closest("a[href]") as HTMLAnchorElement | null
        if (!link || link.target === "_blank" || link.hasAttribute("download")) return

        let url: URL
        try {
          url = new URL(link.href, window.location.href)
        } catch {
          return
        }
        if (url.origin !== window.location.origin) return
        if (url.protocol === "mailto:" || url.protocol === "tel:") return

        const targetHref = url.href
        const startHref = window.location.href
        if (targetHref === startHref) return

        setTimeout(() => {
          if (document.visibilityState === "hidden") return
          if (window.location.href === startHref) {
            window.location.assign(targetHref)
          }
        }, 1000)
      })

      document.addEventListener("astro:page-load", () => {
        initMagneticButtons()
        initTextReveal()
        initScrollAnimations()
        initHamburger()
        initThemeToggle()
        initEmailLinks()
        initSocialLinks()
        initScramble()
      })

      function initThemeToggle() {
        const label = document.getElementById("theme-toggle-label")
        const toggle = document.getElementById("theme-toggle")
        const labelM = document.getElementById("theme-toggle-mobile-label")
        const toggleM = document.getElementById("theme-toggle-mobile")

        function isDark() {
          return document.documentElement.classList.contains("dark")
        }

        function updateLabels() {
          const dark = isDark()
          const text = dark ? "HELL" : "DUNKEL"
          const aria = dark
            ? "Zu Hell-Modus wechseln"
            : "Zu Dunkel-Modus wechseln"
          if (label) label.textContent = text
          if (labelM) labelM.textContent = text
          if (toggle) toggle.setAttribute("aria-label", aria)
          if (toggleM) toggleM.setAttribute("aria-label", aria)
        }

        function applyTheme(dark: boolean) {
          document.documentElement.classList.toggle("dark", dark)
          localStorage.setItem("theme", dark ? "dark" : "light")
          updateLabels()
          window.posthog?.capture("theme_toggled", {
            theme: dark ? "dark" : "light",
          })
        }

        updateLabels()

        toggle?.addEventListener("click", () => applyTheme(!isDark()))
        toggleM?.addEventListener("click", () => applyTheme(!isDark()))
      }

      function initHamburger() {
        const toggle = document.getElementById(
          "nav-toggle"
        ) as HTMLButtonElement | null
        const overlay = document.getElementById(
          "nav-overlay"
        ) as HTMLElement | null
        if (!toggle || !overlay) return

        function open() {
          toggle!.classList.add("is-open")
          overlay!.classList.add("is-open")
          toggle!.setAttribute("aria-expanded", "true")
          overlay!.setAttribute("aria-hidden", "false")
          overlay!.removeAttribute("inert")
          document.body.style.overflow = "hidden"
        }

        function close() {
          toggle!.classList.remove("is-open")
          overlay!.classList.remove("is-open")
          toggle!.setAttribute("aria-expanded", "false")
          overlay!.setAttribute("aria-hidden", "true")
          overlay!.setAttribute("inert", "")
          document.body.style.overflow = ""
        }

        toggle.addEventListener("click", () => {
          toggle.classList.contains("is-open") ? close() : open()
        })

        overlay.querySelectorAll("a").forEach((link) => {
          link.addEventListener("click", close)
        })

        document.addEventListener("keydown", (e) => {
          if (e.key === "Escape") close()
        })
      }

      // Text-Scramble: Nav-Links flimmern kurz durch Zufallszeichen beim Hover
      // Buchstaben settlen von links nach rechts → technischer Charakter
      function initScramble() {
        if (window.matchMedia("(prefers-reduced-motion: reduce)").matches)
          return
        if (!window.matchMedia("(hover: hover)").matches) return

        const CHARS = "ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789"
        const FPS = 30
        const DURATION_MS = 380

        const links =
          document.querySelectorAll<HTMLAnchorElement>(".corner-nav-link")

        links.forEach((link) => {
          if (link.dataset.scrambleInit) return
          link.dataset.scrambleInit = "1"

          const original = link.textContent ?? ""
          let timer: ReturnType<typeof setInterval> | null = null
          let frame = 0
          const totalFrames = Math.round((DURATION_MS / 1000) * FPS)

          link.addEventListener("mouseenter", () => {
            if (timer) clearInterval(timer)
            frame = 0

            timer = setInterval(() => {
              frame++
              const progress = frame / totalFrames

              link.textContent = original
                .split("")
                .map((char, i) => {
                  if (char === " ") return char
                  // Buchstaben settlen von links → rechts
                  if (i / original.length < progress) return char
                  return CHARS[Math.floor(Math.random() * CHARS.length)]
                })
                .join("")

              if (frame >= totalFrames) {
                clearInterval(timer!)
                timer = null
                link.textContent = original
              }
            }, 1000 / FPS)
          })

          link.addEventListener("mouseleave", () => {
            if (timer) {
              clearInterval(timer)
              timer = null
            }
            link.textContent = original
          })
        })
      }

      function initSocialLinks() {
        document
          .querySelectorAll<HTMLAnchorElement>(".footer-social a[href]")
          .forEach((el) => {
            if (el.dataset.phSocialInit) return
            el.dataset.phSocialInit = "1"
            el.addEventListener("click", () => {
              const platform = (
                el.getAttribute("aria-label") ??
                el.textContent ??
                ""
              )
                .replace(/\s*Profil\s*/i, "")
                .trim()
              window.posthog?.capture("social_link_clicked", {
                platform,
                url: el.href,
              })
            })
          })
      }

      // E-Mail Bot-Schutz: mailto wird erst bei Klick per JS zusammengesetzt
      // → kein href="mailto:" im HTML-Quelltext, kein Spam-Bot-Treffer
      function initEmailLinks() {
        document
          .querySelectorAll<HTMLElement>("[data-user][data-domain]")
          .forEach((el) => {
            if (el.dataset.emailInit) return
            el.dataset.emailInit = "1"
            el.style.cursor = "pointer"
            el.addEventListener("click", () => {
              const addr = `${el.dataset.user}@${el.dataset.domain}`
              window.posthog?.capture("contact_email_clicked", { email: addr })
              window.location.href = `mailto:${addr}`
            })
          })
      }
    </script>

    <style>
      /* ── Corner-Logo: oben links ─────────────────────────────────────────── */
      .corner-logo {
        position: fixed;
        top: 2rem;
        left: 2.5rem;
        z-index: 60;
        /* Dezenter Blur-Backdrop hinter dem Text — garantiert Kontrast über
           Bildern (Halbton-Cover etc.), unabhängig vom exakten Bildinhalt.
           Robuster als mix-blend-mode, das durch Stacking-Contexts anderer
           Fixed-Elemente (Cursor, Grain-Overlay, View Transitions) brechen kann. */
        padding: 0.5rem 0.875rem;
        margin: -0.5rem -0.875rem;
        border-radius: 999px;
        background: color-mix(in oklch, var(--background) 55%, transparent);
        backdrop-filter: blur(12px) saturate(160%);
        -webkit-backdrop-filter: blur(12px) saturate(160%);
      }

      .corner-logo-link {
        font-size: var(--text-sm);
        font-weight: 500;
        letter-spacing: var(--tracking-wide);
        color: var(--foreground);
        text-decoration: none;
        transition: opacity 200ms ease;
      }

      .corner-logo-link:hover {
        opacity: 0.6;
      }

      /* ── Corner-Nav: oben rechts ─────────────────────────────────────────── */
      .corner-nav {
        position: fixed;
        top: 2rem;
        right: 2.5rem;
        z-index: 60;
        display: flex;
        flex-direction: row;
        align-items: center;
        gap: 2rem;
        /* Gleicher Blur-Backdrop-Schutz wie .corner-logo */
        padding: 0.5rem 1.125rem;
        margin: -0.5rem -1.125rem;
        border-radius: 999px;
        background: color-mix(in oklch, var(--background) 55%, transparent);
        backdrop-filter: blur(12px) saturate(160%);
        -webkit-backdrop-filter: blur(12px) saturate(160%);
      }

      .corner-nav-link {
        font-size: var(--text-sm);
        color: var(--muted-foreground);
        text-decoration: none;
        transition: color 200ms ease;
      }

      .corner-nav-link:hover {
        color: var(--foreground);
      }

      /* ── Mobile: Logo anpassen, Desktop-Nav ausblenden ─────────────────── */
      @media (max-width: 640px) {
        .corner-logo {
          top: 1.5rem;
          left: 1.5rem;
        }

        .corner-nav {
          display: none;
        }
      }

      /* ── Hamburger: zwei Striche, nur mobil ─────────────────────────────── */
      .nav-toggle {
        display: none;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        gap: 6px;
        width: 44px;
        height: 44px;
        background: color-mix(in oklch, var(--background) 55%, transparent);
        backdrop-filter: blur(12px) saturate(160%);
        -webkit-backdrop-filter: blur(12px) saturate(160%);
        border: none;
        border-radius: 999px;
        cursor: pointer;
        position: fixed;
        top: 1.375rem;
        right: 1.25rem;
        z-index: 70;
        padding: 0;
        -webkit-tap-highlight-color: transparent;
      }

      .nav-toggle.is-open {
        background: none;
        backdrop-filter: none;
        -webkit-backdrop-filter: none;
      }

      .bar {
        display: block;
        width: 22px;
        height: 1.5px;
        background: var(--foreground);
        transform-origin: center;
        transition:
          transform 300ms cubic-bezier(0.16, 1, 0.3, 1),
          background 200ms ease;
      }

      /* Zwei Striche → X: geöffnet liegt der Button über dem Overlay
         (bekannte, solide Hintergrundfarbe) — dort reicht normale Kontrastfarbe. */
      .nav-toggle.is-open .bar {
        background: var(--background);
      }
      .nav-toggle.is-open .bar-1 {
        transform: translateY(3.75px) rotate(45deg);
      }
      .nav-toggle.is-open .bar-2 {
        transform: translateY(-3.75px) rotate(-45deg);
      }

      @media (max-width: 640px) {
        .nav-toggle {
          display: flex;
        }
      }

      /* ── Mobile Overlay ──────────────────────────────────────────────────── */
      .nav-overlay {
        position: fixed;
        inset: 0;
        z-index: 65;
        background: var(--foreground);
        display: flex;
        flex-direction: column;
        justify-content: center;
        padding: 5rem 2.5rem 3rem;
        opacity: 0;
        pointer-events: none;
        transition: opacity 280ms cubic-bezier(0.16, 1, 0.3, 1);
      }

      .nav-overlay.is-open {
        opacity: 1;
        pointer-events: auto;
      }

      /* ── Overlay-Links: daumenfreundlich, groß ───────────────────────────── */
      .nav-overlay-links {
        display: flex;
        flex-direction: column;
        gap: 0;
      }

      .nav-overlay-link {
        display: flex;
        align-items: center;
        font-size: var(--text-3xl);
        font-weight: 500;
        line-height: 1;
        letter-spacing: var(--tracking-tight);
        color: var(--background);
        text-decoration: none;
        min-height: 72px; /* daumenfreundliches Tap-Target */
        border-bottom: 1px solid
          color-mix(in oklch, var(--background) 12%, transparent);
        opacity: 0;
        transform: translateY(12px);
        transition:
          opacity 450ms cubic-bezier(0.16, 1, 0.3, 1),
          transform 450ms cubic-bezier(0.16, 1, 0.3, 1),
          color 150ms ease;
        transition-delay: calc(var(--i) * 60ms + 60ms);
      }

      .nav-overlay-link:first-child {
        border-top: 1px solid
          color-mix(in oklch, var(--background) 12%, transparent);
      }

      .nav-overlay-link:hover,
      .nav-overlay-link[aria-current="page"] {
        color: color-mix(in oklch, var(--background) 55%, transparent);
      }

      .nav-overlay.is-open .nav-overlay-link {
        opacity: 1;
        transform: translateY(0);
      }

      /* ── Overlay-Footer ──────────────────────────────────────────────────── */
      .nav-overlay-footer {
        position: absolute;
        bottom: 2.5rem;
        left: 2.5rem;
        display: flex;
        gap: 1.5rem;
        opacity: 0;
        transition: opacity 350ms ease;
        transition-delay: 280ms;
      }

      .nav-overlay.is-open .nav-overlay-footer {
        opacity: 1;
      }

      .nav-overlay-small {
        font-size: var(--text-xs);
        letter-spacing: var(--tracking-wide);
        text-transform: uppercase;
        color: color-mix(in oklch, var(--background) 35%, transparent);
        text-decoration: none;
        transition: color 150ms ease;
      }

      .nav-overlay-small:hover {
        color: var(--background);
      }

      /* ── Skip-Link (Tastaturnavigation) ─────────────────────────────────── */
      .skip-link {
        position: absolute;
        top: -100%;
        left: 1.5rem;
        z-index: 100;
        background: var(--foreground);
        color: var(--background);
        font-size: var(--text-sm);
        padding: 0.5rem 1rem;
        text-decoration: none;
        transition: top 150ms ease;
      }

      .skip-link:focus {
        top: 1rem;
      }

      /* ── Fokus-Stile für Tastaturnavigation ─────────────────────────────── */
      .corner-logo-link:focus-visible,
      .corner-nav-link:focus-visible {
        outline: 2px solid var(--foreground);
        outline-offset: 4px;
        border-radius: 2px;
      }

      /* ── Theme Toggle ────────────────────────────────────────────────── */
      .theme-toggle {
        position: fixed;
        bottom: 2rem;
        left: 2.5rem;
        z-index: 60;
        background: none;
        border: none;
        padding: 0;
        cursor: pointer;
        font-size: var(--text-xs);
        letter-spacing: var(--tracking-wide);
        text-transform: uppercase;
        font-family: var(--font-sans);
        color: var(--muted-foreground);
        transition: color 200ms ease;
        -webkit-tap-highlight-color: transparent;
      }

      .theme-toggle:hover {
        color: var(--foreground);
      }

      .theme-toggle:focus-visible {
        outline: 2px solid var(--foreground);
        outline-offset: 4px;
        border-radius: 2px;
      }

      @media (max-width: 640px) {
        .theme-toggle {
          display: none; /* auf Mobile: Toggle nur im Hamburger-Overlay */
        }
      }

      @media (prefers-reduced-motion: reduce) {
        .corner-logo-link,
        .corner-nav-link,
        .bar,
        .nav-overlay,
        .nav-overlay-link,
        .nav-overlay-footer,
        .theme-toggle {
          transition: none !important;
        }
      }

      /* ── Footer ──────────────────────────────────────────────────────────── */
      .site-footer {
        margin-top: 6rem;
        padding-top: 2.5rem;
        padding-bottom: 3rem;
        border-top: 1px solid
          color-mix(in oklch, var(--foreground) 12%, transparent);
      }

      .footer-inner {
        display: flex;
        flex-direction: column;
        gap: 2rem;
      }

      /* Obere Zeile */
      .footer-top {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 2rem;
        flex-wrap: wrap;
      }

      .footer-identity {
        display: flex;
        flex-direction: column;
        gap: 0.375rem;
      }

      .footer-name {
        color: var(--foreground);
      }

      /* Social + E-Mail Gruppe */
      .footer-social {
        display: flex;
        flex-wrap: wrap;
        gap: 1.5rem;
        align-items: center;
      }

      /* Gemeinsame Link-Styles */
      .footer-link {
        font-size: var(--text-xs);
        letter-spacing: var(--tracking-wide);
        text-transform: uppercase;
        color: var(--muted-foreground);
        text-decoration: none;
        background: none;
        border: none;
        padding: 0;
        cursor: pointer;
        font-family: var(--font-sans);
        transition: color 200ms ease;
      }

      .footer-link:hover {
        color: var(--foreground);
      }

      .footer-link:focus-visible {
        outline: 2px solid var(--foreground);
        outline-offset: 4px;
        border-radius: 2px;
      }

      /* Untere Zeile */
      .footer-bottom {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        flex-wrap: wrap;
        padding-top: 1.5rem;
        border-top: 1px solid
          color-mix(in oklch, var(--foreground) 8%, transparent);
      }

      .footer-legal {
        display: flex;
        align-items: center;
        gap: 0.75rem;
      }

      .footer-sep {
        color: var(--muted-foreground);
        opacity: 0.4;
      }

      /* Mobile */
      @media (max-width: 640px) {
        .footer-top {
          flex-direction: column;
          gap: 1.5rem;
        }
        .footer-social {
          gap: 1.25rem;
        }
      }

      /* ── Cookiebot-Widget: Standardposition ist unten links und      ── */
      /* ── überlagert dort unseren Theme-Toggle. Auf rechts verschoben. ── */
      #CookiebotWidget {
        left: auto !important;
        right: 2.5rem !important;
      }
    </style>
  </body>
</html>
