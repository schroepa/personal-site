---
---

<dialog id="lightbox" aria-label="Bild in Vollansicht" aria-modal="true">
  <button id="lightbox-close" type="button" aria-label="Schließen">
    <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
      <path d="M4 4l12 12M16 4L4 16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
    </svg>
  </button>
  <figure id="lightbox-figure">
    <img id="lightbox-img" src="" alt="" />
    <figcaption id="lightbox-caption"></figcaption>
  </figure>
</dialog>

<style>
  /* ── Backdrop ───────────────────────────────────────────────────────────── */
  #lightbox::backdrop {
    background: oklch(0.08 0 0 / 0.92);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
  }

  /* ── Dialog ─────────────────────────────────────────────────────────────── */
  #lightbox {
    position: fixed;
    inset: 0;
    margin: auto;
    width: min(92vw, 1200px);
    max-height: 92dvh;
    background: transparent;
    border: none;
    padding: 0;
    overflow: visible;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  #lightbox:not([open]) { display: none; }

  /* ── Figure & Image ─────────────────────────────────────────────────────── */
  #lightbox-figure {
    margin: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    max-height: 92dvh;
  }

  #lightbox-img {
    display: block;
    max-width: 100%;
    max-height: calc(92dvh - 4rem);
    width: auto;
    height: auto;
    object-fit: contain;
    border-radius: 2px;
    animation: lb-in 250ms cubic-bezier(0.16, 1, 0.3, 1) both;
  }

  @keyframes lb-in {
    from { opacity: 0; transform: scale(0.97); }
    to   { opacity: 1; transform: scale(1); }
  }

  /* ── Caption ────────────────────────────────────────────────────────────── */
  #lightbox-caption {
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: oklch(1 0 0 / 0.45);
    text-align: center;
    max-width: 60ch;
    line-height: var(--leading-normal);
  }

  #lightbox-caption:empty { display: none; }

  /* ── Close Button ───────────────────────────────────────────────────────── */
  #lightbox-close {
    position: fixed;
    top: 1.5rem;
    right: 1.5rem;
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: oklch(1 0 0 / 0.1);
    border: 1px solid oklch(1 0 0 / 0.15);
    border-radius: 50%;
    color: oklch(1 0 0 / 0.7);
    cursor: pointer;
    transition: background 200ms ease, color 200ms ease;
    z-index: 10;
  }

  #lightbox-close:hover {
    background: oklch(1 0 0 / 0.2);
    color: oklch(1 0 0);
  }

  @media (prefers-reduced-motion: reduce) {
    #lightbox-img { animation: none; }
  }
</style>

<script>
  function initLightbox() {
    const dialog  = document.getElementById('lightbox') as HTMLDialogElement | null
    const img     = document.getElementById('lightbox-img') as HTMLImageElement | null
    const caption = document.getElementById('lightbox-caption') as HTMLElement | null
    const closeBtn = document.getElementById('lightbox-close') as HTMLButtonElement | null

    if (!dialog || !img || !caption || !closeBtn) return

    let trigger: HTMLElement | null = null

    // Alle Bilder in Prose-Content aktivieren
    document.querySelectorAll<HTMLImageElement>('.prose img, .t-prose img').forEach((el) => {
      // Nicht erneut initialisieren
      if (el.dataset.lightboxInit) return
      el.dataset.lightboxInit = '1'

      el.style.cursor = 'zoom-in'
      el.setAttribute('tabindex', '0')
      el.setAttribute('role', 'button')
      el.setAttribute('aria-label', `Bild vergrößern: ${el.alt || 'Bild'}`)

      function open() {
        trigger = el
        img!.src = el.src
        img!.alt = el.alt
        caption!.textContent = el.alt ?? ''
        dialog!.showModal()
      }

      el.addEventListener('click', open)
      el.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' || e.key === ' ') {
          e.preventDefault()
          open()
        }
      })
    })

    // Schließen via Close-Button
    closeBtn.addEventListener('click', () => dialog.close())

    // Schließen via Backdrop-Klick
    dialog.addEventListener('click', (e) => {
      if (e.target === dialog) dialog.close()
    })

    // Fokus zurückgeben nach Schließen
    dialog.addEventListener('close', () => {
      trigger?.focus()
      trigger = null
    })
  }

  // Initialisierung bei Page-Load und Astro View Transitions
  document.addEventListener('astro:page-load', initLightbox)
</script>
