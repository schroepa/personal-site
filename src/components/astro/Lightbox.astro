---
---

<dialog id="lightbox" aria-label="Bildgalerie" aria-modal="true">
  <!-- Header: Counter + Close -->
  <div id="lightbox-header">
    <span id="lightbox-counter" aria-live="polite"></span>
    <button id="lightbox-close" type="button" aria-label="Galerie schließen">
      <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
        <path d="M2 2l14 14M16 2L2 16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
    </button>
  </div>

  <!-- Bild -->
  <figure id="lightbox-figure">
    <img id="lightbox-img" src="" alt="" />
    <figcaption id="lightbox-caption"></figcaption>
  </figure>

  <!-- Navigation -->
  <nav id="lightbox-nav" aria-label="Bildnavigation">
    <button id="lightbox-prev" type="button" aria-label="Vorheriges Bild">
      <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
        <path d="M12 4L6 10l6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>
    <button id="lightbox-next" type="button" aria-label="Nächstes Bild">
      <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
        <path d="M8 4l6 6-6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>
  </nav>
</dialog>

<style>
  /* ── Backdrop ───────────────────────────────────────────────────────────── */
  #lightbox::backdrop {
    background: oklch(0.06 0 0 / 0.94);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }

  /* ── Dialog ─────────────────────────────────────────────────────────────── */
  #lightbox {
    position: fixed;
    inset: 0;
    margin: auto;
    width: 100dvw;
    height: 100dvh;
    max-width: 100dvw;
    max-height: 100dvh;
    background: transparent;
    border: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
  }

  #lightbox:not([open]) { display: none; }

  /* ── Header ─────────────────────────────────────────────────────────────── */
  #lightbox-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.25rem 1.5rem;
    z-index: 10;
  }

  #lightbox-counter {
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: oklch(1 0 0 / 0.4);
    font-family: var(--font-mono);
  }

  #lightbox-close {
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: oklch(1 0 0 / 0.08);
    border: 1px solid oklch(1 0 0 / 0.12);
    border-radius: 50%;
    color: oklch(1 0 0 / 0.6);
    cursor: pointer;
    transition: background 150ms ease, color 150ms ease;
  }

  #lightbox-close:hover {
    background: oklch(1 0 0 / 0.15);
    color: oklch(1 0 0);
  }

  /* ── Bild ───────────────────────────────────────────────────────────────── */
  #lightbox-figure {
    margin: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.875rem;
    padding: 4rem 1.5rem;
    max-height: 100dvh;
    width: 100%;
    box-sizing: border-box;
  }

  #lightbox-img {
    display: block;
    max-width: min(92vw, 1200px);
    max-height: calc(100dvh - 10rem);
    width: auto;
    height: auto;
    object-fit: contain;
    border-radius: 2px;
    animation: lb-in 220ms cubic-bezier(0.16, 1, 0.3, 1) both;
  }

  @keyframes lb-in {
    from { opacity: 0; transform: scale(0.97); }
    to   { opacity: 1; transform: scale(1); }
  }

  #lightbox-caption {
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: oklch(1 0 0 / 0.35);
    text-align: center;
    max-width: 60ch;
    line-height: var(--leading-normal);
  }

  #lightbox-caption:empty { display: none; }

  /* ── Navigation ─────────────────────────────────────────────────────────── */
  #lightbox-nav {
    position: fixed;
    bottom: 1.5rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 0.75rem;
    z-index: 10;
  }

  #lightbox-prev,
  #lightbox-next {
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: oklch(1 0 0 / 0.08);
    border: 1px solid oklch(1 0 0 / 0.12);
    border-radius: 50%;
    color: oklch(1 0 0 / 0.6);
    cursor: pointer;
    transition: background 150ms ease, color 150ms ease, opacity 150ms ease;
  }

  #lightbox-prev:hover,
  #lightbox-next:hover {
    background: oklch(1 0 0 / 0.15);
    color: oklch(1 0 0);
  }

  #lightbox-prev:disabled,
  #lightbox-next:disabled {
    opacity: 0.2;
    cursor: default;
    pointer-events: none;
  }

  /* Nur 1 Bild: Navigation ausblenden */
  #lightbox-nav:has(#lightbox-prev:disabled + #lightbox-next:disabled) {
    display: none;
  }

  @media (prefers-reduced-motion: reduce) {
    #lightbox-img { animation: none; }
  }
</style>

<script>
  function initLightbox() {
    const dialog   = document.getElementById('lightbox') as HTMLDialogElement | null
    const img      = document.getElementById('lightbox-img') as HTMLImageElement | null
    const caption  = document.getElementById('lightbox-caption') as HTMLElement | null
    const counter  = document.getElementById('lightbox-counter') as HTMLElement | null
    const closeBtn = document.getElementById('lightbox-close') as HTMLButtonElement | null
    const prevBtn  = document.getElementById('lightbox-prev') as HTMLButtonElement | null
    const nextBtn  = document.getElementById('lightbox-next') as HTMLButtonElement | null

    if (!dialog || !img || !caption || !counter || !closeBtn || !prevBtn || !nextBtn) return

    // Alle Bilder im Prose-Bereich sammeln
    const images = Array.from(
      document.querySelectorAll<HTMLImageElement>('.prose img, .t-prose img, .article-prose img')
    )

    let current = 0
    let trigger: HTMLElement | null = null

    // Galerie-Zustand aktualisieren
    function update() {
      const el = images[current]
      if (!el) return

      // Neue Animation auslösen
      img!.style.animation = 'none'
      img!.offsetHeight // reflow
      img!.style.animation = ''

      img!.src = el.src
      img!.alt = el.alt
      caption!.textContent = el.alt ?? ''
      counter!.textContent = `${current + 1} / ${images.length}`

      prevBtn!.disabled = current === 0
      nextBtn!.disabled = current === images.length - 1
    }

    function openAt(index: number, el: HTMLElement) {
      current = index
      trigger = el
      update()
      dialog!.showModal()
    }

    function prev() {
      if (current > 0) { current--; update() }
    }

    function next() {
      if (current < images.length - 1) { current++; update() }
    }

    function close() {
      dialog!.close()
      trigger?.focus()
      trigger = null
    }

    // Klick-Handler auf alle Bilder
    images.forEach((el, i) => {
      if (el.dataset.lightboxInit) return
      el.dataset.lightboxInit = '1'
      el.style.cursor = 'zoom-in'
      el.setAttribute('tabindex', '0')
      el.setAttribute('role', 'button')
      el.setAttribute('aria-label', `Bild öffnen${el.alt ? `: ${el.alt}` : ''}`)

      const open = () => openAt(i, el)
      el.addEventListener('click', open)
      el.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); open() }
      })
    })

    // Buttons
    closeBtn.addEventListener('click', close)
    prevBtn.addEventListener('click', prev)
    nextBtn.addEventListener('click', next)

    // Tastatur
    dialog.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowLeft')  { e.preventDefault(); prev() }
      if (e.key === 'ArrowRight') { e.preventDefault(); next() }
    })

    // Backdrop-Klick schließt
    dialog.addEventListener('click', (e) => {
      if (e.target === dialog) close()
    })

    // Native close-Event (Escape-Taste)
    dialog.addEventListener('close', () => {
      trigger?.focus()
      trigger = null
    })
  }

  document.addEventListener('astro:page-load', initLightbox)
</script>
