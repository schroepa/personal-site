---

<!-- transition:persist hält die Elemente über View Transitions hinweg am Leben -->
<div id="cursor-dot"  aria-hidden="true" transition:persist></div>
<div id="cursor-ring" aria-hidden="true" transition:persist></div>

<style>
  /* cursor:none via CSS — überlebt View Transitions, kein JS-Reset nötig */
  @media (pointer: fine) {
    html { cursor: none !important; }
  }

  #cursor-dot,
  #cursor-ring {
    position: fixed;
    top: 0;
    left: 0;
    pointer-events: none;
    z-index: 9998;
    border-radius: 50%;
    transform: translate(-200px, -200px);
  }

  #cursor-dot {
    width: 6px;
    height: 6px;
    background-color: var(--foreground);
    transition: opacity 200ms ease;
  }

  #cursor-ring {
    width: 28px;
    height: 28px;
    border: 1.5px solid var(--foreground);
    opacity: 0.5;
    transition:
      opacity 200ms ease,
      width 200ms ease,
      height 200ms ease,
      background-color 200ms ease,
      border-color 200ms ease,
      border-radius 200ms ease,
      border-width 200ms ease;
  }

  /* ── Hover-States ─────────────────────────────────────────────────────── */
  body[data-cursor-state="link"] #cursor-ring {
    width: 48px;
    height: 48px;
    opacity: 1;
  }

  body[data-cursor-state="link"] #cursor-dot {
    opacity: 0;
  }

  body[data-cursor-state="button"] #cursor-ring {
    width: 44px;
    height: 44px;
    background-color: color-mix(in oklch, var(--foreground) 15%, transparent);
    border-color: transparent;
    opacity: 1;
  }

  body[data-cursor-state="text"] #cursor-ring {
    width: 2px;
    height: 26px;
    border-radius: 1px;
    border-width: 0;
    background-color: var(--foreground);
    opacity: 0.8;
  }

  @media (pointer: coarse) {
    #cursor-dot, #cursor-ring { display: none; }
    html { cursor: auto !important; }
  }

  @media (prefers-reduced-motion: reduce) {
    #cursor-dot, #cursor-ring { display: none; }
    html { cursor: auto !important; }
  }
</style>

<script>
  (function () {
    if (window.matchMedia('(pointer: coarse)').matches) return;
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    let dot  = document.getElementById('cursor-dot')  as HTMLElement;
    let ring = document.getElementById('cursor-ring') as HTMLElement;

    let mouseX = -200, mouseY = -200;
    let ringX  = -200, ringY  = -200;
    let rafId: number;

    function lerp(a: number, b: number, t: number): number {
      return a + (b - a) * t;
    }

    function tick(): void {
      ringX = lerp(ringX, mouseX, 0.12);
      ringY = lerp(ringY, mouseY, 0.12);
      const rh = ring.offsetWidth / 2;
      dot.style.transform  = `translate(${mouseX - 3}px, ${mouseY - 3}px)`;
      ring.style.transform = `translate(${ringX - rh}px, ${ringY - rh}px)`;
      rafId = requestAnimationFrame(tick);
    }

    // Pointer-Position verfolgen
    document.addEventListener('pointermove', (e: PointerEvent) => {
      mouseX = e.clientX;
      mouseY = e.clientY;
    });

    // Hover-State
    document.addEventListener('mouseover', (e: MouseEvent) => {
      const target = (e.target as HTMLElement).closest('[data-cursor]');
      document.body.dataset.cursorState = target
        ? (target as HTMLElement).dataset.cursor ?? ''
        : '';
      if (!target) delete document.body.dataset.cursorState;
    });

    document.addEventListener('mouseleave', () => {
      delete document.body.dataset.cursorState;
    });

    // Nach jeder View-Transition: Element-Referenzen aktualisieren
    // (transition:persist hält die Elemente, aber nach astro:after-swap
    // ist sichergestellt, dass das DOM stabil ist)
    document.addEventListener('astro:after-swap', () => {
      dot  = document.getElementById('cursor-dot')  as HTMLElement;
      ring = document.getElementById('cursor-ring') as HTMLElement;
    });

    // RAF starten — läuft dauerhaft, überlebt Navigationen
    tick();
  })();
</script>
